    let heroIndex = 0;

    function rotateHeroPhotos() {
      heroIndex = (heroIndex + 1) % heroSets.length;
      heroImages.forEach((image) => image.classList.add("is-changing"));
      setTimeout(() => {
        heroImages.forEach((image, index) => {
          image.src = heroSets[heroIndex][index][0];
          image.alt = heroSets[heroIndex][index][1];
          image.classList.remove("is-changing");
        });
      }, 350);
    }

    if (heroImages.every(Boolean)) {
      setInterval(rotateHeroPhotos, 4200);
    }
