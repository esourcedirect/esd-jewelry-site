      const details = selected.join(" / ");
      const existing = cart.find((item) => item.name === product.cartName && item.details === details);

      if (existing) {
        existing.quantity += 1;
      } else {
        cart.push({ name: product.cartName, price: product.price, details, quantity: 1 });
      }

      renderCart();
      document.getElementById("cart").scrollIntoView({ behavior: "smooth", block: "start" });
    });

    cartItems.addEventListener("click", (event) => {
      const button = event.target.closest("button");
      if (!button) return;
      const item = cart[Number(button.dataset.index)];
      if (button.dataset.action === "increase") item.quantity += 1;
      if (button.dataset.action === "decrease") item.quantity -= 1;
      if (item.quantity <= 0) cart.splice(Number(button.dataset.index), 1);
      renderCart();
    });

    document.getElementById("square-checkout").addEventListener("click", () => {
      if (squareCheckoutUrl) {
        window.location.href = squareCheckoutUrl;
        return;
      }
      checkoutNote.textContent = "Next step: paste your Square checkout link into this page so customers can pay here.";
    });

    const requestedProduct = new URLSearchParams(window.location.search).get("product");
    openProduct(products[requestedProduct] ? requestedProduct : "rings");
    renderCart();
  </script>
</body>
</html>
